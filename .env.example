# ==============================================================================
# eSIM Shop – Environment Variables Example
# ==============================================================================
# Copy this file to .env.local for local development.
# In production, set these variables in the Coolify dashboard for your service.
#
# IMPORTANT FOR NEXT.JS DOCKER BUILDS:
# Environment variables prefixed with NEXT_PUBLIC_ are baked into the client bundle
# at BUILD TIME. You MUST define these as "Build Pack Variables" or build-time env
# variables in Coolify so that they are present during docker build!
# All other variables are server-only and can be set as standard runtime envs.
# ==============================================================================

# ── Supabase (Local/VPS or Cloud) ─────────────────────────────────────────────
# If hosting Supabase locally in your VPS via Coolify, use the Kong gateway URL
# (e.g., http://your-vps-ip:8000 or a domain routed to Kong).
# Otherwise, use your Supabase cloud project credentials.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key – NEVER expose to the browser (server-only runtime variable)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── esimaccess API ────────────────────────────────────────────────────────────
# Credentials from your https://www.esimaccess.com API account.
ESIMACCESS_API_URL=https://api.esimaccess.com/api/v1/open
ESIMACCESS_ACCESS_CODE=your-esimaccess-access-code

# ── Sellauth (Billing & Shop Gateway) ─────────────────────────────────────────
# Required for processing checkout payments and handling webhooks.
SELLAUTH_API_KEY=your-sellauth-api-key
SELLAUTH_SHOP_ID=your-sellauth-shop-id
SELLAUTH_WEBHOOK_SECRET=your-sellauth-webhook-secret

# ── E-Mail (SMTP) ─────────────────────────────────────────────────────────────
# Credentials for transactional emails (order confirmations, delivery).
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM_NAME=eSIM Shop
SMTP_FROM_ADDRESS=noreply@example.com

# ── Exchange Rate API (Optional) ──────────────────────────────────────────────
# Updates the system settings rate for USD/EUR conversion automatically.
EXCHANGE_RATE_API_URL=https://open.er-api.com/v6/latest/USD
EXCHANGE_RATE_API_KEY=

# ── App & Security ────────────────────────────────────────────────────────────
# The public canonical URL of this storefront.
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Secret token used to protect /api/cron/* endpoints (min 32 chars).
CRON_SECRET=your-random-cron-secret-min-32-chars

# ── Admin Access ──────────────────────────────────────────────────────────────
# The email address of the Supabase user granted access to the shop admin dashboard.
ADMIN_EMAIL=admin@example.com
NEXT_PUBLIC_ADMIN_EMAIL=admin@example.com

# ── Node / Environment ────────────────────────────────────────────────────────
NODE_ENV=production

# ── pure-wallet (Self-Hosted Crypto Gateway) ──────────────────────────────────
# The URL where your pure-wallet service is running (e.g. http://wallet:7777 inside VPS Docker network).
PURE_WALLET_URL=http://localhost:7777
# Secret key shared with pure-wallet to sign and verify callback webhook signatures.
SHOP_WEBHOOK_SECRET=your-shared-webhook-secret-min-32-chars

# ── AI API Credentials (Optional) ─────────────────────────────────────────────
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat
XAI_API_KEY=your-xai-api-key
