# ==============================================================================
# eSIM Shop – Environment Variables Example
# ==============================================================================
# Copy this file to .env.local for local development.
# In production, set these variables in your Coolify dashboard.
#
# IMPORTANT FOR NEXT.JS DOCKER BUILDS:
# Environment variables prefixed with NEXT_PUBLIC_ are baked into the client bundle
# at BUILD TIME. You MUST define these as "Build Pack Variables" / build-time env
# variables in Coolify so that they are present during docker build!
# All other variables are server-only and can be set as standard runtime envs.
# ==============================================================================

# ── DATABASE & SESSION (REQUIRED) ─────────────────────────────────────────────
# Connection string to your PostgreSQL database (running on the VPS via Coolify).
# Example: postgresql://postgres:password@your-vps-ip:5432/postgres
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Secret key used to sign session cookies. Set a long random string.
JWT_SECRET=your-random-jwt-secret-min-32-chars

# ── APP & PUBLIC URL (REQUIRED) ───────────────────────────────────────────────
# The public canonical URL of this storefront.
# Must be set as a BUILD TIME variable because Next.js bakes it into client pages.
NEXT_PUBLIC_APP_URL=https://your-domain.com

# The email address of the administrator (optional, used to show the admin dashboard link in the navbar).
# Must be set as a BUILD TIME variable.
NEXT_PUBLIC_ADMIN_EMAIL=admin@example.com

# ── esimaccess API (REQUIRED) ──────────────────────────────────────────────────
# Credentials from your https://www.esimaccess.com API account.
ESIMACCESS_API_URL=https://api.esimaccess.com/api/v1/open
ESIMACCESS_ACCESS_CODE=your-esimaccess-access-code

# ── Offline Fallback (Optional) ────────────────────────────────────────────────
# Static merchant LTC address to use as a fallback if the pure-wallet API is offline.
# If set, checkout sessions will still succeed by converting to LTC locally.
# Expected payments will be stored in the database for mapping when the wallet comes online.
FALLBACK_LTC_ADDRESS=your-static-litecoin-fallback-address

# ── E-Mail SMTP (REQUIRED) ────────────────────────────────────────────────────
# Credentials for transactional emails (order confirmations, delivery).
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM_NAME=eSIM Shop
SMTP_FROM_ADDRESS=noreply@example.com

# ── pure-wallet PAYMENT GATEWAY (REQUIRED) ──────────────────────────────────
# The URL where your pure-wallet service is running (e.g., http://localhost:7777).
PURE_WALLET_URL=http://localhost:7777
# Secret key shared with pure-wallet to sign and verify callback webhook signatures.
SHOP_WEBHOOK_SECRET=your-shared-webhook-secret-min-32-chars

# ── SECURITY CRON KEY (REQUIRED) ──────────────────────────────────────────────
# Secret token used to protect /api/cron/* endpoints (min 32 chars).
CRON_SECRET=your-random-cron-secret-min-32-chars

# ── Exchange Rate API (OPTIONAL) ──────────────────────────────────────────────
# Updates the system settings rate for USD/EUR conversion automatically.
# If left blank, the app will fall back to the default rate stored in system_settings.
EXCHANGE_RATE_API_URL=https://open.er-api.com/v6/latest/USD
EXCHANGE_RATE_API_KEY=

# ── AI API Credentials (OPTIONAL) ─────────────────────────────────────────────
# Key and model used for any integrated assistant features.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
XAI_API_KEY=
